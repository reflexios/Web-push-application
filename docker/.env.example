# database config
DATABASE_URL=postgres://push:push@host.docker.internal:5432/push_platform
DATABASE_MAX_CONNECTIONS=20
DATABASE_MIN_CONNECTIONS=2
DATABASE_ACQUIRE_TIMEOUT_SECS=5
DATABASE_IDLE_TIMEOUT_SECS=300
DATABASE_MAX_LIFETIME_SECS=0

# backend bind address
BACKEND_PORT=8080

# Set true to use UNIX socket instead tcp
USE_UNIX_SOCKET=false

# default vapid subject (for clients who don't set vapid subject)
DEFAULT_VAPID_SUBJECT=mailto:admin@example.com

# secret for encrypt/decrypt VAPID PRIVATE KEY, must be set only 1 time (openssl rand -hex 64).
# VAPID_KEY_ENCRYPTION_SECRET=

# admin web credentials
ADMIN_LOGIN=admin
ADMIN_PASSWORD=admin

# origin react url (for CORS)
ADMIN_ORIGIN=http://host.docker.internal:80

# key for obtaining the session cookie (openssl rand -hex 64).
# COOKIE_SECRET=

# secret for HMAC-hash, must be set only 1 time (openssl rand -hex 32).
# API_KEY_HASH_SECRET=

# maximum number of simultaneous HTTP requests to push servers per message (POST/send).
SEND_MAX_CONCURRENCY=50

# secure mode: enables HTTPS-related behavior (secure cookies).
SECURE_MODE=false

RUST_LOG=info,push_platform=debug,sqlx=warn
